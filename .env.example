# Copy this file to .env before class if you want to customize settings.

# Optional provider setting:
# - leave blank to auto-use local Ollama first, then Hugging Face
# - set to ollama to force Ollama
# - set to openai to force OpenAI
# - set to huggingface to force the local Hugging Face path
LLM_PROVIDER=

# Local Ollama settings.
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:latest

# OpenAI API settings if you want a cloud model later.
# Add your real key in a local .env file, not in source control.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Default Hugging Face model used by the classroom scripts when running locally.
# Use google/flan-t5-base on lower-memory machines if large is too slow.
HF_MODEL_NAME=google/flan-t5-large

# Optional fallback model if the preferred model is not downloaded yet.
HF_FALLBACK_MODEL_NAME=google/flan-t5-base

# Optional Neo4j settings for the actual graph database demo.
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
